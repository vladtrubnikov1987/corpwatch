# CorpWatch environment example
# Copy this file to .env and replace placeholder values.
# Do not commit real .env to GitHub.

# Application
APP_HOST=0.0.0.0
APP_PORT=8000
API_KEY=change_me

# Database
DB_HOST=db
DB_PORT=3306
DB_NAME=corpwatch
DB_USER=corpwatch_user
DB_PASSWORD=change_me
DB_ROOT_PASSWORD=change_me_root

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=corpwatch.project@example.com
SMTP_PASSWORD=change_me
SMTP_FROM=corpwatch.project@example.com
SMTP_TO=admin@example.com
SMTP_USE_TLS=true

# Monitoring
DEFAULT_TIMEOUT_SECONDS=5
DEFAULT_MAX_RESPONSE_TIME_MS=1000
DEFAULT_CHECK_INTERVAL_SECONDS=60
DEFAULT_FAILURE_THRESHOLD=3

# Background worker
BACKGROUND_WORKER_ENABLED=true
SCHEDULER_TICK_SECONDS=10

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log